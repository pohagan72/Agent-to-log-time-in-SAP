# Azure AI Foundry - Claude API
AZURE_CLAUDE_API_KEY="your-api-key-here"
AZURE_CLAUDE_ENDPOINT="https://your-azure-endpoint.services.ai.azure.com/anthropic/v1/messages"
AZURE_CLAUDE_API_VERSION="2023-06-01"
AZURE_CLAUDE_MODEL="claude-sonnet-4-5"

# SAP Connection
SAP_HOSTNAME="your-sap-host.example.com"
SAP_CLIENT="100"
SAP_ODATA_PATH="/sap/opu/odata/sap/ZHR_TIME_ENTRY_SRV"

# User Info (find these on your SAP Time Entry page)
SAP_PERS_NUMBER="00000000"
SAP_USER_NAME="your-username"
SAP_USER_DISPLAY_NAME="Your Name"
SAP_USER_TITLE="Your Title"
SAP_COMPANY="Your Company"
SAP_COST_CENTER="000000 / Your Cost Center"
SAP_DEFAULT_ROLE="ZADMIN"
