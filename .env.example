# API Proxy (Entra ID authenticated — API key stays server-side)
PROXY_ENDPOINT="https://sap-hours-proxy.azurewebsites.net/api/claude"
ENTRA_CLIENT_ID="your-entra-app-client-id"
ENTRA_TENANT_ID="your-azure-ad-tenant-id"

# SAP Connection (user info is auto-discovered at runtime)
SAP_HOSTNAME="your-sap-host.example.com"
SAP_CLIENT="100"
SAP_ODATA_PATH="/sap/opu/odata/sap/ZHR_TIME_ENTRY_SRV"
