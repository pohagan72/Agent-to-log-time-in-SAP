# Azure AI Foundry - Claude API
AZURE_CLAUDE_API_KEY="your-api-key-here"
AZURE_CLAUDE_ENDPOINT="https://your-azure-endpoint.services.ai.azure.com/anthropic/v1/messages"
AZURE_CLAUDE_MODEL="claude-sonnet-4-5"
AZURE_CLAUDE_API_VERSION="2023-06-01"

# SAP Connection (user info is auto-discovered at runtime)
SAP_HOSTNAME="your-sap-host.example.com"
SAP_CLIENT="100"
SAP_ODATA_PATH="/sap/opu/odata/sap/ZHR_TIME_ENTRY_SRV"

# Enterprise proxy (optional — omit these to use direct API mode)
# When set, the extension authenticates via Entra ID and calls the proxy
# instead of the Claude API directly. No API key is distributed to users.
# PROXY_ENDPOINT="https://sap-hours-proxy.azurewebsites.net/api/claude"
# ENTRA_CLIENT_ID="18e3ec56-ab30-427f-84cf-b3ee61e4887d"
# ENTRA_TENANT_ID="2a9f86a9-29e7-44bd-8863-849373d53db8"
